  "workflow": [
    {
      "step": 1,
      "description": "External client traffic enters through the global edge and is forwarded to the API gateway.",
      "services": [
        "svc-frontdoor",
        "svc-apim"
      ]
    },
    {
      "step": 2,
      "description": "The API gateway validates caller identity and applies access policies before allowing the request through.",
      "services": [
        "svc-apim",
        "svc-entra"
      ]
    },
