  },
  "workflow": [
    {
      "step": 1,
      "description": "Azure Data Factory ingests source data and lands it in the Storage Account for training and later scoring.",
      "services": [
        "svc-adf",
        "svc-storage"
      ]
    },
    {
      "step": 2,
      "description": "Azure Machine Learning registers the landed datasets from Storage Account and initiates the training pipeline.",
      "services": [
        "svc-storage",
        "svc-azureml"
      ]
    },
    {
      "step": 3,
      "description": "Azure Machine Learning provisions AML Managed Compute to execute model training jobs at scale.",
      "services": [
        "svc-azureml",
        "svc-aml-compute"
      ]
    },
    {
      "step": 4,
      "description": "AML Managed Compute reads training data from Storage Account, trains the model, and writes resulting artifacts back to storage under Azure Machine Learning control.",
      "services": [
        "svc-aml-compute",
        "svc-storage",
        "svc-azureml"
      ]
    },
    {
      "step": 5,
      "description": "After validation, Azure Machine Learning publishes the trained model to an AML Batch Endpoint for offline scoring workloads.",
      "services": [
        "svc-azureml",
        "svc-aml-batch"
      ]
    },
    {
      "step": 6,
      "description": "New scoring files in Storage Account are processed by the AML Batch Endpoint, which writes prediction outputs back to storage.",
      "services": [
        "svc-storage",
        "svc-aml-batch"
      ]
    },
    {
      "step": 7,
      "description": "Azure Machine Learning also deploys the approved model to an AML Online Endpoint for real-time inference.",
      "services": [
        "svc-azureml",
        "svc-aml-online"
      ]
    },
    {
      "step": 8,
      "description": "The AML Online Endpoint emits operational telemetry to Azure Monitor, which stores and exposes it through Log Analytics.",
      "services": [
        "svc-aml-online",
        "svc-azure-monitor",
        "svc-log-analytics"
      ]
    }
  ],
  "architecturePrompt": "A machine learning pipeline with data ingestion, training, and inference endpoints"
}