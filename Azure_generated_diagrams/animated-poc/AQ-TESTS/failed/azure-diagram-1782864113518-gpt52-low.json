  },
  "workflow": [
    {
      "step": 1,
      "description": "A scheduled pipeline run starts and acquires secrets needed to connect to external sources.",
      "services": [
        "svc-adf",
        "svc-keyvault"
      ]
    },
    {
      "step": 2,
      "description": "Data Factory extracts data from multiple sources and lands raw/staged files in the landing zone.",
      "services": [
        "svc-adf",
        "svc-storage"
      ]
    },
    {
      "step": 3,
      "description": "Data Factory performs transformations and loads curated datasets into the Azure SQL data warehouse.",
      "services": [
        "svc-adf",
        "svc-sqldb"
      ]
    },
    {
      "step": 4,
      "description": "Purview scans the landing/staging area to catalog new assets and classify sensitive data.",
      "services": [
        "svc-purview",
        "svc-storage"
      ]
    },
    {
      "step": 5,
      "description": "Purview scans the Azure SQL warehouse to capture schemas, lineage, and business glossary mappings.",
      "services": [
        "svc-purview",
        "svc-sqldb"
      ]
    },
    {
      "step": 6,
      "description": "End users authenticate via Entra ID and Power BI Embedded obtains tokens to render embedded reports.",
      "services": [
        "svc-powerbi",
        "svc-entra"
      ]
    },
    {
      "step": 7,
      "description": "Power BI Embedded queries the SQL warehouse to populate visuals and enable interactive analytics.",
      "services": [
        "svc-powerbi",
        "svc-sqldb"
      ]
    },
    {
      "step": 8,
      "description": "Operational health and failures from pipeline runs are sent to Azure Monitor and retained in Log Analytics for investigation.",
      "services": [
        "svc-adf",
        "svc-monitor",
        "svc-loganalytics"
      ]
    }
  ],
  "architecturePrompt": "A data warehouse with Azure SQL Database, Data Factory for scheduled imports from multiple sources, Purview for data governance and cataloging, and Power BI embedded reports"
}