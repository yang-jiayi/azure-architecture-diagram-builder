  "workflow": [
    {
      "step": 1,
      "description": "A user uploads a document image or file into cloud storage, which initiates the processing pipeline.",
      "services": [
        "svc-storage",
        "svc-functions"
      ]
    },
    {
      "step": 2,
      "description": "The orchestration function sends the uploaded image to Computer Vision to analyze visual content and image characteristics.",
      "services": [
        "svc-functions",
        "svc-cv"
      ]
    },
    {
      "step": 3,
      "description": "The same orchestration function submits the document to Document Intelligence to extract form fields, tables, and text.",
      "services": [
        "svc-functions",
        "svc-docint"
      ]
    },
    {
      "step": 4,
      "description": "The function combines extracted text and analysis results, then calls Language to classify the document and create a summary.",
      "services": [
        "svc-functions",
        "svc-docint",
        "svc-language"
      ]
    },
    {
      "step": 5,
      "description": "The orchestration layer assembles all AI outputs into a normalized document record and writes it to the operational data store.",
      "services": [
        "svc-functions",
        "svc-cosmos"
      ]
    },
    {
      "step": 6,
      "description": "The processed document content and metadata are pushed into Azure Cognitive Search to enable retrieval and discovery.",
      "services": [
        "svc-functions",
        "svc-search"
      ]
    },
    {
      "step": 7,
      "description": "Azure Cognitive Search can also refresh or enrich its index from document records persisted in Cosmos DB.",
      "services": [
        "svc-cosmos",
        "svc-search"
      ]
    },
    {
      "step": 8,
      "description": "Azure Functions sends telemetry about execution health, throughput, and failures to the monitoring pipeline.",
      "services": [
        "svc-functions",
        "svc-monitor"
      ]
    },
    {
      "step": 9,
      "description": "Azure Monitor forwards collected metrics and logs into Log Analytics for investigation and operational reporting.",
      "services": [
        "svc-monitor",
        "svc-logs"
      ]
    }
  ],
  "architecturePrompt": "A smart document processing platform that uses Computer Vision to analyze uploaded images, Document Intelligence to extract form data, Language to classify and summarize content, all coordinated through Azure Functions with results stored in Cosmos DB and searchable via Cognitive Search"
}