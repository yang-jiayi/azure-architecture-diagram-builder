# Normalize line endings so files that run inside Linux containers are never
# checked out with CRLF (which breaks shell shebangs => "/start.sh: not found"
# on Alpine). Protects contributors on Windows regardless of core.autocrlf.

# Default: let Git decide, but always store/checkout text with LF.
* text=auto eol=lf

# Files executed in the container MUST be LF.
*.sh text eol=lf
start.sh text eol=lf
nginx.conf text eol=lf
Dockerfile text eol=lf
*.conf text eol=lf

# Binary assets — never touch.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.zip binary
*.tgz binary
*.pdf binary
