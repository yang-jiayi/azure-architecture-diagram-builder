  "workflow": [
    {
      "step": 1,
      "description": "User authenticates via Entra ID and sends query through App Service frontend.",
      "services": [
        "app-service",
        "entra-id"
      ]
    },
    {
      "step": 2,
      "description": "App Service forwards the query to Azure AI Foundry for orchestration.",
      "services": [
        "app-service",
        "ai-foundry"
      ]
    },
    {
      "step": 3,
      "description": "AI Foundry checks Azure Cache for Redis for a cached response to a similar query. If found, returns cached answer.",
      "services": [
        "ai-foundry",
        "redis"
      ]
    },
    {
      "step": 4,
      "description": "If not cached, AI Foundry uses Azure Cognitive Search to perform hybrid (vector + keyword) retrieval over documents stored in Blob Storage.",
      "services": [
        "ai-foundry",
        "ai-search",
        "storage"
      ]
    },
    {
      "step": 5,
      "description": "AI Foundry sends retrieved context and query to Azure OpenAI GPT-5 to generate an answer.",
      "services": [
        "ai-foundry",
        "openai"
      ]
    },
    {
      "step": 6,
      "description": "AI Foundry stores the query and generated answer in Redis cache for future semantic caching.",
      "services": [
        "ai-foundry",
        "redis"
      ]
    },
    {
      "step": 7,
      "description": "AI Foundry returns the answer to App Service, which presents it to the user.",
      "services": [
        "ai-foundry",
        "app-service"
      ]
    },
    {
      "step": 8,
      "description": "Throughout the process, App Service and AI Foundry send telemetry to Azure Monitor, which forwards logs to Log Analytics for monitoring.",
      "services": [
        "app-service",
        "ai-foundry",
        "monitor",
        "log-analytics"
      ]
    }
