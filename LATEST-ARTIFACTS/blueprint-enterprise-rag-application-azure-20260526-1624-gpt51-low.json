  "workflow": [
    {
      "step": 1,
      "description": "Enterprise users access the RAG web or mobile application hosted on App Service and submit a question."
    },
    {
      "step": 2,
      "description": "App Service redirects to Microsoft Entra ID to validate the user identity and enforce RBAC before allowing access to the RAG features."
    },
    {
      "step": 3,
      "description": "The authenticated request is sent from App Service to Azure AI Foundry, which orchestrates the end-to-end RAG workflow."
    },
    {
      "step": 4,
      "description": "Azure AI Foundry interacts with Azure Cache for Redis to read or write semantic and response cache entries, reducing latency and model calls when possible."
    },
    {
      "step": 5,
      "description": "For cache misses or fresh context, Azure AI Foundry queries Azure AI Search using hybrid vector and keyword retrieval to fetch relevant documents."
    },
    {
      "step": 6,
      "description": "Enterprise documents and chunked content stored in Azure Blob Storage are indexed into Azure AI Search, keeping the search index in sync with source content."
    },
    {
      "step": 7,
      "description": "Azure AI Foundry calls Azure OpenAI (GPT-5) with the user question and retrieved context to generate a grounded, enterprise-ready answer."
    },
    {
      "step": 8,
      "description": "Azure AI Foundry persists conversation metadata, user state, and configuration updates into Azure SQL Database for audit, personalization, and session continuity."
    },
    {
      "step": 9,
      "description": "App Service emits application and dependency telemetry to Azure Monitor for performance and reliability tracking."
    },
    {
      "step": 10,
      "description": "Azure Monitor forwards consolidated metrics and logs to Log Analytics, where they are stored and queried for diagnostics, alerting, and usage analytics."
    }
  ],
