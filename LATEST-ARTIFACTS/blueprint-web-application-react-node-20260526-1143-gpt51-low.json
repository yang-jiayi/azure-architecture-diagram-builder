  "workflow": [
    {
      "step": 1,
      "description": "The web user accesses the application via a browser, sending requests through Azure Front Door."
    },
    {
      "step": 2,
      "description": "Azure Front Door routes the request to Azure Static Web Apps to serve the React frontend."
    },
    {
      "step": 3,
      "description": "The React frontend hosted in Azure Static Web Apps invokes backend APIs via Azure API Management."
    },
    {
      "step": 4,
      "description": "Azure API Management validates, secures, and forwards API calls to the Node.js backend running on Azure App Service."
    },
    {
      "step": 5,
      "description": "The Node.js backend reads and writes relational application data in Azure Database for PostgreSQL."
    },
    {
      "step": 6,
      "description": "The Node.js backend stores and retrieves image files as blob objects in Azure Storage."
    },
    {
      "step": 7,
      "description": "Azure App Service emits platform and custom application metrics to Azure Monitor for health and performance tracking."
    },
    {
      "step": 8,
      "description": "Azure App Service sends application and infrastructure logs to Log Analytics for centralized querying and analysis."
    },
    {
      "step": 9,
      "description": "Azure Static Web Apps integrates with Microsoft Entra ID to validate user identities and enforce access control for the web application."
    }
