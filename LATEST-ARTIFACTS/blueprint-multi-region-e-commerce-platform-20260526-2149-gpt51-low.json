  "workflow": [
    {
      "step": 1,
      "description": "Customers from multiple regions browse the e-commerce site and initiate browsing or order actions."
    },
    {
      "step": 2,
      "description": "Azure Front Door routes the HTTP(S) request to the closest healthy regional Azure App Service backend."
    },
    {
      "step": 3,
      "description": "Azure App Service reads and writes user session data and cached responses in Azure Cache for Redis for low-latency access."
    },
    {
      "step": 4,
      "description": "Azure App Service reads product catalog and pricing data from globally distributed Azure Cosmos DB."
    },
    {
      "step": 5,
      "description": "For a checkout request, Azure App Service creates a new order record in the regional Azure SQL Database."
    },
    {
      "step": 6,
      "description": "Azure App Service publishes an order-created event to Event Grid for downstream asynchronous processing."
    },
    {
      "step": 7,
      "description": "Event Grid triggers Azure Functions subscribed to order-related events for tasks such as payment confirmation and fulfillment."
    },
    {
      "step": 8,
      "description": "Azure Functions update the corresponding order status and payment details in Azure SQL Database."
    },
    {
      "step": 9,
      "description": "Azure Functions adjust inventory and related catalog attributes in Azure Cosmos DB to reflect the completed order."
    }
  ],
