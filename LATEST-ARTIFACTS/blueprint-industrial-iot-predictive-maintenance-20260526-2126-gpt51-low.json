  "workflow": [
    {
      "step": 1,
      "description": "Industrial sensors on manufacturing equipment generate telemetry every 5 seconds and send it to the local Azure IoT Edge Gateway."
    },
    {
      "step": 2,
      "description": "The Azure IoT Edge Gateway aggregates OT sensor data, applies any local filtering, and forwards the telemetry securely toward Azure via the OT/IT boundary."
    },
    {
      "step": 3,
      "description": "Azure Private Link provides private, segregated connectivity from the OT network into Azure, delivering telemetry into Azure IoT Hub without traversing the public internet."
    },
    {
      "step": 4,
      "description": "Azure IoT Hub Device Provisioning Service performs secure, zero-touch provisioning and enrollment of IoT devices, registering them with Azure IoT Hub."
    },
    {
      "step": 5,
      "description": "Azure IoT Hub ingests the high-volume telemetry stream and forwards messages to Azure Stream Analytics for real-time processing."
    },
    {
      "step": 6,
      "description": "Azure Stream Analytics performs sub-second anomaly detection and updates Azure Digital Twins with current state and context for assets and the facility."
    },
    {
      "step": 7,
      "description": "Azure Stream Analytics writes curated, near-real-time telemetry and anomaly results into Azure Data Lake Storage for hot storage retention."
    },
    {
      "step": 8,
      "description": "Azure Synapse Analytics reads from Azure Data Lake Storage to run batch analytics, trend analysis, and reporting over historical telemetry with long-term retention."
    },
    {
      "step": 9,
      "description": "Time Series Insights is fed from Azure Data Lake Storage (and associated time-series data) to provide rich, time-series exploration and visualization."
    },
    {
      "step": 10,
      "description": "Operations engineers access Time Series Insights dashboards to monitor equipment health, investigate anomalies, and explore trends."
    },
    {
      "step": 11,
      "description": "Azure Synapse Analytics supplies historical datasets from Azure Data Lake Storage to Azure Machine Learning for training predictive maintenance models."
    },
    {
      "step": 12,
      "description": "Azure Machine Learning deploys trained models back into Azure Stream Analytics, enabling updated predictive and anomaly detection logic in the real-time pipeline."
    }
  ],
