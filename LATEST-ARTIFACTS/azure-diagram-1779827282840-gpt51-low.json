  "workflow": [
    {
      "step": 1,
      "description": "Enterprise user navigates to the RAG web application, which initiates authentication with Microsoft Entra ID.",
      "services": [
        "enterprise-users",
        "app-service",
        "entra-id"
      ]
    },
    {
      "step": 2,
      "description": "Upon successful sign-in, App Service retrieves necessary secrets and connection strings from Key Vault to call downstream services.",
      "services": [
        "app-service",
        "key-vault"
      ]
    },
    {
      "step": 3,
      "description": "User submits a query; App Service sends an authenticated RAG orchestration request with user context to Azure AI Foundry.",
      "services": [
        "enterprise-users",
        "app-service",
        "azure-ai-foundry"
      ]
    },
    {
      "step": 4,
      "description": "Azure AI Foundry first checks Azure Cache for Redis for a semantically similar query and cached response, updating the cache if needed.",
      "services": [
        "azure-ai-foundry",
        "azure-cache-redis"
      ]
    },
    {
      "step": 5,
      "description": "If fresh grounding data is required, Azure AI Foundry calls Azure AI Search to run hybrid vector and keyword retrieval over indexed content in Blob Storage.",
      "services": [
        "azure-ai-foundry",
        "azure-ai-search",
        "blob-storage"
      ]
    },
    {
      "step": 6,
      "description": "Azure AI Foundry composes an augmented prompt using retrieved context and invokes Azure OpenAI GPT-5 for answer generation and reasoning.",
      "services": [
        "azure-ai-foundry",
        "azure-openai"
      ]
    },
    {
      "step": 7,
      "description": "Azure AI Foundry persists or updates conversation state, user-specific metadata, and configuration in SQL Database, then returns the final answer to App Service.",
      "services": [
        "azure-ai-foundry",
        "sql-database",
        "app-service"
      ]
    },
    {
      "step": 8,
      "description": "App Service presents the grounded response to the enterprise user and sends telemetry to Azure Monitor, which forwards logs and metrics to Log Analytics for analysis.",
      "services": [
        "app-service",
        "enterprise-users",
        "azure-monitor",
        "log-analytics"
      ]
    }
  ],
