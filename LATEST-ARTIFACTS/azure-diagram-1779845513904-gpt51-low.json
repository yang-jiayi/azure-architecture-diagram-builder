  "metadata": {
    "architectureName": "Industrial IoT Predictive Maintenance Platform",
    "author": "Azure Architect",
    "version": "1.0",
    "date": "2026-05-26",
    "savedAt": "2026-05-27T01:31:53.903Z"
  },
  "workflow": [
    {
      "step": 1,
      "description": "Industrial sensors generate telemetry every 5 seconds and send it to the on-premises Azure IoT Edge Gateway for initial aggregation and normalization.",
      "services": [
        "s-industrial-sensors",
        "s-iot-edge-gateway"
      ]
    },
    {
      "step": 2,
      "description": "The Azure IoT Edge Gateway forwards aggregated telemetry through Azure Private Link into Azure IoT Hub, maintaining strict OT/IT network segregation.",
      "services": [
        "s-iot-edge-gateway",
        "s-private-link",
        "s-iot-hub"
      ]
    },
    {
      "step": 3,
      "description": "Azure IoT Edge Gateway uses Azure IoT Hub Device Provisioning Service to perform secure, zero-touch provisioning and enrolment of new sensors against the correct IoT Hub instance.",
      "services": [
        "s-iot-edge-gateway",
        "s-dps",
        "s-iot-hub"
      ]
    },
    {
      "step": 4,
      "description": "Azure IoT Hub streams incoming telemetry into Azure Stream Analytics jobs, enabling sub-second processing pipelines for anomaly detection.",
      "services": [
        "s-iot-hub",
        "s-stream-analytics"
      ]
    },
    {
      "step": 5,
      "description": "Azure Stream Analytics calls Azure Machine Learning for predictive maintenance scoring and updates Azure Digital Twins with contextualized asset state and anomaly information.",
      "services": [
        "s-stream-analytics",
        "s-azure-ml",
        "s-digital-twins"
      ]
    },
    {
      "step": 6,
      "description": "Azure Stream Analytics writes hot-path telemetry, anomaly flags, and contextual data into Azure Data Lake Storage to support 6-month hot storage and downstream analytics.",
      "services": [
        "s-stream-analytics",
        "s-data-lake"
      ]
    },
    {
      "step": 7,
      "description": "Azure Synapse Analytics loads curated telemetry from Azure Data Lake Storage to run batch analytics, trend analysis, and reporting over long-term historical data.",
      "services": [
        "s-data-lake",
        "s-synapse"
      ]
    },
    {
      "step": 8,
      "description": "Time Series Insights consumes telemetry stored in Azure Data Lake Storage to provide interactive time-series dashboards and visualizations for operators.",
      "services": [
        "s-data-lake",
        "s-tsi"
      ]
    },
    {
      "step": 9,
      "description": "Azure Machine Learning accesses long-term telemetry in Azure Data Lake Storage to train and retrain predictive maintenance models, which are then deployed for real-time scoring.",
      "services": [
        "s-azure-ml",
        "s-data-lake"
      ]
    },
    {
      "step": 10,
      "description": "Azure Stream Analytics publishes operational metrics to Azure Monitor, which forwards them to Log Analytics for centralized observability and SLA tracking.",
      "services": [
        "s-stream-analytics",
        "s-azure-monitor",
        "s-log-analytics"
      ]
    }
  ],
  "architecturePrompt": "An industrial IoT predictive maintenance platform for a manufacturing facility with 5,000+ sensors generating telemetry every 5 seconds, requiring real-time anomaly detection with sub-second latency, batch analytics for trend analysis, secure device provisioning and management, OT/IT network segregation with Private Link, 99.9% uptime SLA, 6-month hot storage and 7-year cold retention, using IoT Hub for ingestion, Stream Analytics for real-time processing, Azure ML for predictive models, Data Lake for raw storage, Synapse Analytics for reporting, Time Series Insights for dashboards, and Digital Twins for facility modeling"
}