  "workflow": [
    {
      "step": 1,
      "description": "OT devices send telemetry over a segregated OT network, which is routed via Azure Private Link into Azure IoT Hub for secure ingestion.",
      "services": [
        "svc-private-link",
        "svc-iot-hub"
      ]
    },
    {
      "step": 2,
      "description": "Microsoft Entra ID enforces secure authentication and role-based access for device provisioning and operator interactions with IoT Hub.",
      "services": [
        "svc-entra-id",
        "svc-iot-hub"
      ]
    },
    {
      "step": 3,
      "description": "Azure IoT Hub forwards continuous telemetry streams from 5,000+ sensors to Azure Stream Analytics for sub-second anomaly detection.",
      "services": [
        "svc-iot-hub",
        "svc-stream-analytics"
      ]
    },
    {
      "step": 4,
      "description": "Azure Machine Learning trains predictive maintenance models using historical telemetry from Azure Data Lake Storage and publishes them for Stream Analytics to consume.",
      "services": [
