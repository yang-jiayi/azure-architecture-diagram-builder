  "workflow": [
    {
      "step": 1,
      "description": "Industrial sensors on manufacturing equipment send telemetry every 5 seconds into the Azure IoT Edge Gateway on the OT network."
    },
    {
      "step": 2,
      "description": "The Azure IoT Edge Gateway aggregates, preprocesses, and securely forwards OT telemetry over the OT/IT boundary using Azure Private Link."
    },
    {
      "step": 3,
      "description": "Azure Private Link delivers the traffic privately into Azure, where Azure IoT Hub ingests the device telemetry for bi-directional communication."
    },
    {
      "step": 4,
      "description": "Azure IoT Hub streams the incoming telemetry into Azure Stream Analytics for real-time, sub-second anomaly detection processing."
    },
    {
      "step": 5,
      "description": "Azure Stream Analytics enriches telemetry by updating Azure Digital Twins with the latest equipment and facility state for contextual insights."
    },
    {
      "step": 6,
      "description": "Azure Stream Analytics invokes Azure Machine Learning models for online scoring to predict failures and maintenance needs in real time."
    },
    {
      "step": 7,
      "description": "Azure Stream Analytics writes curated, hot-path telemetry and anomaly results into Azure Data Lake Storage to support 6-month hot retention."
    },
    {
      "step": 8,
      "description": "Azure Synapse Analytics runs scheduled batch jobs over data in Azure Data Lake Storage for historical trend analysis and reporting."
    },
    {
      "step": 9,
      "description": "Azure Time Series Insights consumes time-series data from Azure Data Lake Storage to provide interactive dashboards and exploration for operators."
    },
    {
      "step": 10,
      "description": "Microsoft Entra ID issues tokens and enforces RBAC for Azure IoT Hub and related services, securing device and service access."
    },
    {
      "step": 11,
      "description": "Azure IoT Hub Device Provisioning Service performs secure, zero-touch provisioning of IoT Edge Gateway and connected devices in the OT network."
    },
    {
      "step": 12,
      "description": "Azure IoT Hub publishes platform health and performance metrics to Azure Monitor to support 99.9% uptime SLA monitoring and alerting."
    },
    {
      "step": 13,
      "description": "Azure Monitor forwards logs and metrics into Log Analytics for centralized observability across IoT, analytics, and platform components."
    }
  ],
