  "workflow": [
    {
      "step": 1,
      "description": "Industrial sensors generate OT telemetry every 5 seconds and send it to the on-premises IoT Edge gateway for aggregation.",
      "services": [
        "s-industrial-sensors",
        "s-iot-edge-gateway"
      ]
    },
    {
      "step": 2,
      "description": "The IoT Edge gateway forwards aggregated telemetry through Azure Private Link to Azure IoT Hub over a segregated OT/IT network path.",
      "services": [
        "s-iot-edge-gateway",
        "s-private-link",
        "s-iot-hub"
      ]
    },
    {
      "step": 3,
      "description": "Devices are securely onboarded and associated with IoT Hub using Azure IoT Hub Device Provisioning Service under Microsoft Entra ID control.",
      "services": [
        "s-dps",
        "s-iot-hub",
        "s-entra"
      ]
    },
    {
      "step": 4,
      "description": "Azure IoT Hub continuously streams incoming telemetry into Azure Stream Analytics jobs for sub-second anomaly detection.",
      "services": [
        "s-iot-hub",
        "s-stream-analytics"
      ]
    },
    {
      "step": 5,
      "description": "Azure Stream Analytics invokes predictive models trained in Azure Machine Learning to score telemetry in real time for predictive maintenance insights.",
      "services": [
        "s-stream-analytics",
        "s-aml"
      ]
    },
    {
      "step": 6,
      "description": "Anomaly results and enriched telemetry are written from Stream Analytics into Azure Data Lake Storage to satisfy hot and cold retention requirements.",
      "services": [
        "s-stream-analytics",
        "s-data-lake"
      ]
    },
    {
      "step": 7,
      "description": "Azure Synapse Analytics reads historical data from Data Lake to run batch analytics and trend reporting across multi-year telemetry.",
      "services": [
        "s-data-lake",
        "s-synapse"
      ]
    },
    {
      "step": 8,
      "description": "Stream Analytics publishes near real-time time-series data and anomalies to Time Series Insights, while updating Azure Digital Twins with contextualized asset state.",
      "services": [
        "s-stream-analytics",
        "s-tsi",
        "s-digital-twins"
      ]
    },
    {
      "step": 9,
      "description": "Plant operators authenticate via Microsoft Entra ID and use Time Series Insights, Synapse reports, and Digital Twins views to monitor equipment and respond to alerts.",
      "services": [
        "s-plant-operators",
        "s-tsi",
        "s-synapse",
        "s-digital-twins",
        "s-entra"
      ]
    },
    {
      "step": 10,
      "description": "Azure Stream Analytics emits operational metrics to Azure Monitor, which consolidates health data and forwards it to Log Analytics for centralized observability.",
      "services": [
        "s-stream-analytics",
        "s-azure-monitor",
        "s-log-analytics"
      ]
    }
  ],
  "architecturePrompt": "An industrial IoT predictive maintenance platform for a manufacturing facility with 5,000+ sensors generating telemetry every 5 seconds, requiring real-time anomaly detection with sub-second latency, batch analytics for trend analysis, secure device provisioning and management, OT/IT network segregation with Private Link, 99.9% uptime SLA, 6-month hot storage and 7-year cold retention, using IoT Hub for ingestion, Stream Analytics for real-time processing, Azure ML for predictive models, Data Lake for raw storage, Synapse Analytics for reporting, Time Series Insights for dashboards, and Digital Twins for facility modeling"
}