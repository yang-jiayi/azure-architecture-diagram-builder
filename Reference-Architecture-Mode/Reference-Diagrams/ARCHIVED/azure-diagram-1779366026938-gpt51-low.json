  "workflow": [
    {
      "step": 1,
      "description": "Industrial sensors send telemetry over the OT network, which reaches Azure IoT Hub through a private endpoint exposed via Azure Private Link.",
      "services": [
        "private-link",
        "iot-hub"
      ]
    },
    {
      "step": 2,
      "description": "Azure IoT Hub continuously forwards high-frequency telemetry streams into Azure Stream Analytics jobs for real-time processing.",
      "services": [
        "iot-hub",
        "stream-analytics"
      ]
    },
    {
      "step": 3,
      "description": "Azure Stream Analytics calls the AML Online Endpoint backed by Azure Machine Learning to score each event for anomalies with sub-second latency.",
      "services": [
        "stream-analytics",
        "aml-online-endpoint",
        "azure-ml"
      ]
    },
    {
      "step": 4,
      "description": "Enriched telemetry and anomaly flags are used to update Azure Digital Twins and are simultaneously pushed into Azure Time Series Insights for real-time dashboards.",
      "services": [
        "stream-analytics",
        "digital-twins",
        "time-series-insights"
      ]
    },
    {
      "step": 5,
      "description": "Azure Stream Analytics writes both raw and processed telemetry into Azure Data Lake Storage to support 6-month hot and long-term cold retention.",
      "services": [
        "stream-analytics",
        "data-lake"
      ]
    },
    {
      "step": 6,
      "description": "Azure Synapse Analytics reads historical data from Azure Data Lake Storage, runs batch analytics and trend detection, and optionally publishes aggregates to Azure Time Series Insights.",
      "services": [
        "data-lake",
        "synapse",
        "time-series-insights"
      ]
    },
    {
      "step": 7,
      "description": "Microsoft Entra ID authenticates administrators for secure device provisioning in Azure IoT Hub and grants operators access to Azure Time Series Insights dashboards.",
      "services": [
        "entra-id",
        "iot-hub",
        "time-series-insights"
      ]
    },
    {
      "step": 8,
      "description": "Azure Stream Analytics emits operational metrics to Azure Monitor, which forwards logs and metrics to Log Analytics for centralized monitoring and alerting.",
      "services": [
        "stream-analytics",
        "azure-monitor",
        "log-analytics"
      ]
    }
  ],
  "architecturePrompt": "An industrial IoT predictive maintenance platform for a manufacturing facility with 5,000+ sensors generating telemetry every 5 seconds, requiring real-time anomaly detection with sub-second latency, batch analytics for trend analysis, secure device provisioning and management, OT/IT network segregation with Private Link, 99.9% uptime SLA, 6-month hot storage and 7-year cold retention, using IoT Hub for ingestion, Stream Analytics for real-time processing, Azure ML for predictive models, Data Lake for raw storage, Synapse Analytics for reporting, Time Series Insights for dashboards, and Digital Twins for facility modeling"
