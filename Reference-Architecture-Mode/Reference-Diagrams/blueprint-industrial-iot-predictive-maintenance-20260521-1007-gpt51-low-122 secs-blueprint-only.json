  "workflow": [
    {
      "step": 1,
      "description": "Industrial IoT sensors in the OT network send high-frequency telemetry to the on-premises industrial gateway."
    },
    {
      "step": 2,
      "description": "The industrial gateway securely forwards aggregated telemetry from the OT network toward Azure via the Private Link endpoint, maintaining OT/IT segregation."
    },
    {
      "step": 3,
      "description": "Traffic enters Azure over Private Link and is ingested by IoT Hub for reliable, scaled telemetry ingestion."
    },
    {
      "step": 4,
      "description": "IoT Hub routes device telemetry streams into Azure Stream Analytics for sub-second real-time processing and anomaly detection."
    },
    {
      "step": 5,
      "description": "Stream Analytics pushes processed time series and anomaly flags to Time Series Insights to power real-time dashboards."
    },
    {
      "step": 6,
      "description": "Stream Analytics updates Azure Digital Twins with live state changes and anomaly information for virtual facility modeling."
    },
    {
      "step": 7,
      "description": "Stream Analytics writes enriched telemetry into Azure Data Lake Storage as hot data, supporting 6-month high-performance retention and lifecycle policies for long-term cold storage."
    },
    {
      "step": 8,
      "description": "Azure Synapse Analytics runs scheduled and ad-hoc batch queries over Data Lake, performing trend and reliability analysis on historical telemetry."
    },
    {
      "step": 9,
      "description": "Synapse outputs training datasets into Azure Machine Learning, which trains predictive maintenance models using historical trends and failure patterns."
    },
    {
      "step": 10,
      "description": "Azure Machine Learning operationalizes and deploys trained models back into Azure Stream Analytics for inline scoring and real-time anomaly prediction."
    },
    {
      "step": 11,
      "description": "IoT Hub emits platform metrics and diagnostics to Azure Monitor for health monitoring and to support the 99.9% uptime SLA."
    },
    {
      "step": 12,
      "description": "Azure Monitor forwards telemetry and logs into Log Analytics workspaces for centralized querying, alerting, and integration with SIEM tools."
    },
    {
      "step": 13,
      "description": "Device Provisioning Service securely provisions and assigns IoT devices to IoT Hub instances using Microsoft Entra ID-backed identities and policies."
    },
    {
      "step": 14,
      "description": "Operations engineers access Time Series Insights dashboards to visualize anomalies, trends, and digital twin states for predictive maintenance decisions."
    }
  ],
