  "workflow": [
    {
      "step": 1,
      "description": "Industrial sensors on manufacturing equipment generate telemetry every 5 seconds and send it to the Azure IoT Edge Gateway in the OT network."
    },
    {
      "step": 2,
      "description": "The Azure IoT Edge Gateway aggregates telemetry and forwards it securely over Azure Private Link, maintaining OT/IT network segregation."
    },
    {
      "step": 3,
      "description": "Azure Private Link delivers the traffic privately to Azure IoT Hub, which terminates device connections and ingests high-volume telemetry."
    },
    {
      "step": 4,
      "description": "Azure IoT Hub streams telemetry into Azure Stream Analytics for real-time processing and sub-second anomaly detection."
    },
    {
      "step": 5,
      "description": "Azure Machine Learning provides deployed predictive maintenance models that Stream Analytics loads for real-time scoring of incoming telemetry."
    },
    {
      "step": 6,
      "description": "Azure Stream Analytics sends enriched events and anomaly flags to Azure Digital Twins to update the facility and equipment twin graph for contextual insights."
    },
    {
      "step": 7,
      "description": "Azure Stream Analytics writes raw and enriched telemetry into Azure Data Lake Storage, supporting 6-month hot and 7-year cold retention policies."
    },
    {
      "step": 8,
      "description": "Azure Synapse Analytics runs batch analytics and trend analysis jobs over data in Azure Data Lake Storage for reporting and deeper insights."
    },
    {
      "step": 9,
      "description": "Time Series Insights consumes telemetry from Azure Data Lake Storage to provide operators with time-series exploration and interactive dashboards."
    },
    {
      "step": 10,
      "description": "Azure Stream Analytics emits platform metrics and health signals to Azure Monitor to support the 99.9% uptime service level target."
    },
    {
      "step": 11,
      "description": "Azure Monitor forwards collected metrics and logs into Log Analytics for centralized querying, diagnostics, and alerting across IoT and analytics services."
    },
    {
      "step": 12,
      "description": "Microsoft Entra ID authenticates users and provides RBAC tokens for accessing Time Series Insights and other operator-facing experiences."
    },
    {
      "step": 13,
      "description": "Operations engineers sign in and use Time Series Insights dashboards to monitor equipment behavior, investigate anomalies, and support predictive maintenance decisions."
    }
  ],
