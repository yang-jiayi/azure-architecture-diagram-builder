# ─── Azure OpenAI Configuration ───
# SECURITY: Azure OpenAI calls are proxied server-side by the co-located token
# server (server/token-server.js) at /api/openai. The API key is NEVER shipped
# to the browser. Keyless auth (managed identity / `az login`) is preferred; a
# key is only used as a fallback when one is provided to the server.
#
#   Local dev: scripts/start-token-server.sh bridges these VITE_ values to the
#     server-side names the proxy reads (AZURE_OPENAI_ENDPOINT / AZURE_OPENAI_API_KEY).
#   Container/ACA: set AZURE_OPENAI_ENDPOINT (and optionally AZURE_OPENAI_API_KEY)
#     as RUNTIME env — azd/Bicep and scripts/update_aca.sh wire this for you.
VITE_AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
VITE_AZURE_OPENAI_API_KEY=your-api-key-here   # dev convenience / server-side fallback — never bundled into the client

# Azure subscription used by helper scripts (e.g. scripts/llm-cost-report.py).
# Keep your real subscription ID out of committed code — set it here in .env.
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000

# Model Deployments (configure one or more)
# The app supports model selection in the UI - configure all deployments you want to use

# GPT-5.1 (Hybrid) - Fast by default (reasoning=none), optional reasoning when needed
VITE_AZURE_OPENAI_DEPLOYMENT_GPT51=gpt-5.1

# GPT-5.2 (Reasoning Model) - Best for complex architectures
VITE_AZURE_OPENAI_DEPLOYMENT_GPT52=gpt-5.2-chat

# GPT-5.2 Codex (Reasoning) - Optimized for code/IaC generation
VITE_AZURE_OPENAI_DEPLOYMENT_GPT52CODEX=gpt-5.2-codex
VITE_AZURE_OPENAI_DEPLOYMENT_GPT53CODEX=gpt-5.3-codex

# GPT-5.4 (Reasoning Model) - Most capable frontier model for professional work
VITE_AZURE_OPENAI_DEPLOYMENT_GPT54=gpt-5.4

# GPT-5.4 Mini (Reasoning Model) - Compact frontier model, fast and cost-efficient
VITE_AZURE_OPENAI_DEPLOYMENT_GPT54MINI=gpt-5.4-mini

# DeepSeek V3.2 Speciale - Strong structured output at lower cost (Chat Completions API)
VITE_AZURE_OPENAI_DEPLOYMENT_DEEPSEEK=DeepSeek-V3.2-Speciale
VITE_AZURE_OPENAI_DEPLOYMENT_DEEPSEEK_V4_PRO=DeepSeek-V4-Pro

# Grok 4.1 Fast - Fast non-reasoning model from xAI (Chat Completions API)
VITE_AZURE_OPENAI_DEPLOYMENT_GROK4FAST=grok-4-1-fast-non-reasoning
VITE_AZURE_OPENAI_DEPLOYMENT_GROK43=grok-4.3
VITE_AZURE_OPENAI_DEPLOYMENT_MISTRALLARGE3=Mistral-Large-3
VITE_AZURE_OPENAI_DEPLOYMENT_KIMIK25=Kimi-K2.5

# Legacy: Default deployment (used if specific model deployments not set)
# VITE_AZURE_OPENAI_DEPLOYMENT=your-deployment-name-here

# ─── Azure Speech Service (Avatar Presenter) ───
# Keyless auth: the container uses DefaultAzureCredential (az login in dev,
# managed identity in ACA) — no API key required or stored.
#
# VITE_SPEECH_REGION is a build-time flag that enables the "Present Critique"
# button. Set it to your Speech resource region (westus2, eastus2, etc.).
# AZURE_SPEECH_REGION is the runtime env var read by the token server inside
# the container (set as an ACA environment variable, not a build arg).
VITE_SPEECH_REGION=westus2
# AZURE_SPEECH_REGION and AZURE_SPEECH_RESOURCE_ID are runtime env vars read by the
# token server inside the container (set as ACA environment variables, not build args).
# AZURE_SPEECH_RESOURCE_ID is the full resource ID from `az cognitiveservices account show --query id`.
# VITE_AVATAR_CHARACTER=lisa
# VITE_AVATAR_STYLE=casual-sitting
# VITE_AVATAR_VOICE=en-US-AvaMultilingualNeural

# ─── Application Insights (Telemetry) ───
# Connection string from your App Insights resource in Azure Portal
# If not set, telemetry is disabled (app runs without tracking)
VITE_APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=your-key;IngestionEndpoint=https://your-region.in.applicationinsights.azure.com/

# ─── Azure Deployment Configuration (for scripts/deploy_aca.sh) ───
# These are only needed if deploying to Azure Container Apps

# Azure Container Registry name
ACR_NAME=your-acr-name

# Azure Container App name
ACA_APP_NAME=azure-diagram-builder

# Azure Resource Group
RESOURCE_GROUP=your-resource-group

# Docker image name (used in ACR)
IMAGE_NAME=azure-diagram-builder
