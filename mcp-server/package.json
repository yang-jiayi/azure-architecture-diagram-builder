{
  "name": "azure-diagram-builder-mcp",
  "version": "1.0.0",
  "description": "MCP server exposing Azure Architecture Diagram Builder capabilities as tools for az prototype and other MCP clients",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "azure-diagram-mcp": "dist/index.js"
  },
  "scripts": {
    "sync:icons": "node scripts/sync-icon-map.mjs",
    "prebuild": "npm run sync:icons",
    "build": "tsc && cp src/iconMap.generated.json dist/iconMap.generated.json",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --http",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/dagre": "^0.7.54",
    "dagre": "^0.8.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
