# Allowlist-style .dockerignore: ignore everything by default, then re-include
# only the paths the Dockerfile actually needs. Keeps the ACR build context
# small (tens of MB instead of hundreds) and protects against accidental
# inclusion of new docs / research dirs.

**

# --- Build manifests & configs ---
!package.json
!package-lock.json
!index.html
!vite.config.ts
!tsconfig.json
!tsconfig.node.json
!eslint.config.js

# --- App source ---
!src/**

# --- Runtime assets served by nginx ---
!nginx.conf
!start.sh
!Azure_Public_Service_Icons/**

# --- Speech token server ---
!server/**

# --- MCP server (separate workspace, built in stage 1) ---
!mcp-server/package.json
!mcp-server/package-lock.json
!mcp-server/tsconfig.json
!mcp-server/src/**
!mcp-server/scripts/**

# --- Build-time env files generated by scripts/update_aca.sh ---
!.env.build*
!.env.appinsights*

# --- Re-exclusions inside allowed paths ---
**/node_modules
**/dist
**/.DS_Store
